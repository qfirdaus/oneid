# Database
*.sql
!/docs/migrations/*.sql

# Konfigurasi runtime local/sensitif. Struktur directory kekal dalam Git,
# tetapi nilai staging/production tidak boleh di-commit.
/.private/*
!/.private/.gitkeep

# Logs
*.log

# OS
Thumbs.db
.DS_Store

# Node
node_modules/

# Vendor (jika boleh install semula)
vendors/

# Upload
videos/*
public_docs/*
public_img/*
/.idea/
/.vscode/

# Runtime data selepas migrasi ke public root
/public/public_img/*
/public/public_docs/*
/public/videos/*

# Local rollback evidence dan quarantine payload
/storage/quarantine/*
!/storage/quarantine/.gitkeep
/storage/backups/*
!/storage/backups/.gitkeep
/storage/runtime/
