# Uploaded assets must never be executed as server-side scripts.
<FilesMatch "(?i)\.(php[0-9]?|phtml|phar|cgi|pl|py|sh|exe|dll|bat|cmd|ps1)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
